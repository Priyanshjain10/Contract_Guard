# ContractGuard Environment Variables
# Copy to .env and fill in real values

# Groq API (primary LLM provider — required at startup)
GROQ_API_KEY=your-groq-api-key

# Anthropic API (installed but not actively called; any non-empty string works)
ANTHROPIC_API_KEY=placeholder

# Database (optional; omit to use in-memory audit trail only)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/contractguard

# ChromaDB local path (must be a local filesystem path, not a URL)
CHROMA_URL=./chroma_db

# Twilio (WhatsApp alerts — all three are optional; omit for silent fallback)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Note: a7_lifecycle_monitor.py reads TWILIO_WHATSAPP_FROM for the sender number.
# TWILIO_FROM_NUMBER is kept for backwards compatibility but TWILIO_WHATSAPP_FROM takes priority.
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# RBI rate for MSME Act interest calculation (default 6.5%)
RBI_RATE=6.5
